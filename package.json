{
  "name": "ClashFox",
  "version": "0.4.8",
  "buildNumber": 1,
  "description": "ClashFox GUI for Mihomo",
  "license": "GPL-3.0",
  "author": "Kuochiang Lu <lukuochiang@gmail.com> (https://github.com/lukuochiang/ClashFox)",
  "main": "src/main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "dev": "node static/scripts/bump-version.js && node -e 'const p=require(\"./package.json\"); console.log(`> ClashFox@${p.version} dev (buildNumber: ${p.buildNumber})`)' && CLASHFOX_DEV=1 electron .",
    "build:mac": "node static/scripts/build-mac.js",
    "build:mac:x64": "node static/scripts/build-mac.js --arch x64",
    "build:mac:arm64": "node static/scripts/build-mac.js --arch arm64",
    "build:mac:universal": "node static/scripts/build-mac.js --arch universal",
    "build:mac:alpha": "node static/scripts/build-mac.js --channel alpha",
    "build:mac:beta": "node static/scripts/build-mac.js --channel beta",
    "build:mac:rc": "node static/scripts/build-mac.js --channel rc",
    "build:mac:stable": "node static/scripts/build-mac.js --channel stable",
    "clean:dist": "rm -rf dist artifacts"
  },
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^26.8.1",
    "electron-reload": "^1.5.0"
  },
  "build": {
    "appId": "com.clashfox.gui",
    "productName": "ClashFox",
    "electronLanguages": [
      "en"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/maxmind/**/*",
      "node_modules/mmdb-lib/**/*",
      "node_modules/tiny-lru/**/*"
    ],
    "afterPack": "static/scripts/after-pack.js",
    "compression": "maximum",
    "npmRebuild": false,
    "files": [
      "src/**/*",
      "static/**/*",
      "package.json",
      "!static/helper",
      "!static/helper/**/*",
      "!static/scripts",
      "!static/scripts/**/*",
      "!**/.DS_Store"
    ],
    "extraResources": [
      {
        "from": "static/helper",
        "to": "helper"
      },
      {
        "from": "static/default.yaml",
        "to": "default.yaml"
      },
      {
        "from": "static/geoip/geoip.metadb",
        "to": "geoip.metadb"
      },
      {
        "from": "static/geoip/geoip-lite.dat",
        "to": "geoip-lite.dat"
      },
      {
        "from": "static/geoip/GeoLite2-ASN.mmdb",
        "to": "GeoLite2-ASN.mmdb"
      },
      {
        "from": "static/geoip/GeoLite2-City.mmdb",
        "to": "GeoLite2-City.mmdb"
      },
      {
        "from": "static/geoip/GeoLite2-Country.mmdb",
        "to": "GeoLite2-Country.mmdb"
      },
      {
        "from": "static/geoip/geosite.dat",
        "to": "geosite.dat"
      }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "src/ui/assets/icns/logo.icns",
      "identity": null,
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64",
            "universal"
          ]
        },
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64",
            "universal"
          ]
        }
      ]
    },
    "publish": [
      {
        "provider": "github"
      }
    ]
  },
  "dependencies": {
    "maxmind": "^4.3.24",
    "mmdb-lib": "^2.1.1",
    "tiny-lru": "^11.2.11"
  }
}
